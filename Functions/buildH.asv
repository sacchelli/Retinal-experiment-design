function H = buildH(C, F, G, N)

n = size(C,2);
q = size(C,1);
m = size(G,2);

dHk = eye(size(F));

col = [C*dHk*G];

for i=2:N
    dHk=dHk*F;
    col=[col;C*dHk*G];
end

col3=col;

mat=col;

for i=2:N
    col=[zeros(q,m);col(1:end-q,:)];
    mat=[mat,col];
end



%%
dHk = eye(size(F));
col2 = zeros(N*q,m);
col2(1:q,:) = C*dHk*G;
for i=2:N
    dHk=dHk*F;
    col2((i-1)*q+1:i*q,:)=C*dHk*G;
end

mat2= zeros(N*q,N*m)


for i=1:N
    mat((i-1)*q+1:end,
end

%%
H=mat;

max(max(abs(col3-col2)))

end